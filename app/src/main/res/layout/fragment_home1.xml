<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f3f1f1">

    <!-- Loading indicator (centered) -->
    <ProgressBar
        android:id="@+id/progressbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true" />

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ══════════════════════════════
                 🔍  Search Box
                 ══════════════════════════════ -->
            <EditText
                android:id="@+id/search_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search your items"
                android:background="@drawable/search_gb"
                android:padding="12dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true" />

            <!-- Search Results RecyclerView
                 (hidden by default, shown when user types) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/search_rec"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:visibility="gone"
                android:nestedScrollingEnabled="false" />

            <!-- ══════════════════════════════
                 ⭐  Popular Products
                 ══════════════════════════════ -->
            <TextView
                android:id="@+id/tv_popular_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Popular Products"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="20dp" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/pop_viewpager"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false" />

            <!-- ══════════════════════════════
                 🧺  Explore Categories
                 ══════════════════════════════ -->
            <TextView
                android:id="@+id/tv_explore_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore Products"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="25dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/explore_rec"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                android:scrollbars="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <!-- ══════════════════════════════
                 👍  Recommended Products
                 ══════════════════════════════ -->
            <TextView
                android:id="@+id/tv_recommended_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recommended For You"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="25dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recommended_rec"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                android:scrollbars="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>